import json
from pathlib import Path

def cell_md(text):
    return {
        "cell_type": "markdown",
        "metadata": {},
        "source": text.splitlines(keepends=True),
    }

def cell_code(code):
    return {
        "cell_type": "code",
        "execution_count": None,
        "metadata": {},
        "outputs": [],
        "source": code.splitlines(keepends=True),
    }

nb = {
    "cells": [],
    "metadata": {
        "kernelspec": {"display_name": "Python 3", "language": "python", "name": "python3"},
        "language_info": {"name": "python", "version": "3.x"},
    },
    "nbformat": 4,
    "nbformat_minor": 5,
}

nb["cells"].append(cell_md(
"""# CL 1.0 Demo — Congruity Logistics

This notebook computes **Congruity Logistics (CL 1.0)** from a dataset and demonstrates how **reducing structural dissipation** (empty kilometers) increases CL.

Metric:

**CL = V / (E + I + S + ε)**

Where:
- **V** = useful logistic value (payload × useful_km)
- **E** = energy dissipation (fuel/energy proxy)
- **I** = informational dissipation (replans, exceptions, delays, rework)
- **S** = structural dissipation (empty_km + idle_time)
"""))

nb["cells"].append(cell_code(
"""import pandas as pd
import matplotlib.pyplot as plt

DATA_PATH = "../data/sample_logistics_dataset.csv"
epsilon = 1

df = pd.read_csv(DATA_PATH)
df.head()
"""))

nb["cells"].append(cell_code(
"""# Compute CL components
df["V_event"] = df["payload"] * df["useful_km"]

V = df["V_event"].sum()
E = df["fuel"].sum()

I = (
    df["replans"].sum()
    + df["exceptions"].sum()
    + df["delay"].sum()
    + df["rework"].sum()
)

S = df["empty_km"].sum() + df["idle_time"].sum()

CL = V / (E + I + S + epsilon)

V, E, I, S, CL
"""))

nb["cells"].append(cell_md(
"""## Baseline vs Optimized Scenario (simple simulation)

We simulate an optimization by reducing **empty_km** by a fixed percentage and recompute CL.
This does not claim a universal improvement, it only demonstrates the metric behavior under reduced structural dissipation.
"""))

nb["cells"].append(cell_code(
"""def compute_cl(df_in, epsilon=1):
    df_local = df_in.copy()
    V = (df_local["payload"] * df_local["useful_km"]).sum()
    E = df_local["fuel"].sum()
    I = (
        df_local["replans"].sum()
        + df_local["exceptions"].sum()
        + df_local["delay"].sum()
        + df_local["rework"].sum()
    )
    S = df_local["empty_km"].sum() + df_local["idle_time"].sum()
    CL = V / (E + I + S + epsilon)
    return V, E, I, S, CL

baseline = compute_cl(df, epsilon=epsilon)

df_opt = df.copy()
reduction = 0.30  # 30% empty_km reduction example
df_opt["empty_km"] = df_opt["empty_km"] * (1 - reduction)

optimized = compute_cl(df_opt, epsilon=epsilon)

baseline, optimized
"""))

nb["cells"].append(cell_code(
"""labels = ["Baseline", "Optimized"]
values = [baseline[-1], optimized[-1]]

plt.figure(figsize=(6,4))
plt.bar(labels, values)
plt.title("Congruity Logistics (CL 1.0), Baseline vs Optimized")
plt.ylabel("CL")

plt.savefig("../figures/cl_improvement.png")

plt.show()

improvement = (optimized[-1] - baseline[-1]) / baseline[-1] * 100
improvement
"""))

out_dir = Path("notebooks")
out_dir.mkdir(parents=True, exist_ok=True)
(out_dir / "cl_demo.ipynb").write_text(json.dumps(nb, indent=2))
print("Generated notebooks/cl_demo.ipynb")
